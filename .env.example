# ── LLM Providers ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_PRIMARY_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-3.5-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# ── Qdrant (vector store) ───────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=atlas_chunks
QDRANT_API_KEY=                   # leave blank for local dev

# ── Redis (query + embedding cache) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_SECONDS=3600

# ── Retrieval ───────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=20                 # candidates fetched from each retriever
RERANKER_TOP_K=5                   # final docs after reranking
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Chunking ────────────────────────────────────────────────────────────────────
CHUNK_STRATEGY=recursive           # fixed | recursive | semantic
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Observability ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENABLE_PROMETHEUS=true

# ── API ─────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
