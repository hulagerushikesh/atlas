# ══════════════════════════════════════════════════════════════════════════════
# Atlas — environment configuration
# Copy this file to .env and fill in values marked [REQUIRED].
# Values marked [OPTIONAL] have defaults and can be left as-is.
# Quick start: bash scripts/setup_dev.sh
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider  [REQUIRED] ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_PRIMARY_MODEL=gpt-4o-mini               # [OPTIONAL]
OPENAI_FALLBACK_MODEL=gpt-3.5-turbo            # [OPTIONAL]
OPENAI_EMBEDDING_MODEL=text-embedding-3-small  # [OPTIONAL]
OPENAI_EMBEDDING_DIMENSIONS=1536               # [OPTIONAL] must match model

# ── Qdrant (vector store)  [REQUIRED for /ingest and /query] ──────────────────
# Local:  docker run -p 6333:6333 qdrant/qdrant
# Cloud:  https://cloud.qdrant.io (set QDRANT_API_KEY too)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=atlas_chunks            # [OPTIONAL]
QDRANT_API_KEY=                                # [OPTIONAL] blank = local dev

# ── Redis (query + embedding cache)  [OPTIONAL] ───────────────────────────────
# Atlas runs without Redis — caching is gracefully skipped if unavailable.
# Local:  docker run -p 6379:6379 redis:7
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_SECONDS=3600

# ── Retrieval tuning  [OPTIONAL] ──────────────────────────────────────────────
RETRIEVAL_TOP_K=20                             # candidates per retriever
RERANKER_TOP_K=5                               # final docs after reranking
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Chunking  [OPTIONAL] ──────────────────────────────────────────────────────
CHUNK_STRATEGY=recursive                       # fixed | recursive | semantic
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Observability  [OPTIONAL] ─────────────────────────────────────────────────
LOG_LEVEL=INFO                                 # DEBUG | INFO | WARNING | ERROR
ENABLE_PROMETHEUS=true                         # exposes /metrics

# ── Auth  [OPTIONAL] ──────────────────────────────────────────────────────────
# Set AUTH_ENABLED=true to require API keys on all endpoints.
# Then create your first key with: python scripts/create_key.py --name "my app"
AUTH_ENABLED=false
ADMIN_SECRET=                                  # required to call POST /keys

# ── API server  [OPTIONAL] ────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8010
API_WORKERS=1
